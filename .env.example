# ============================================
# APOS Environment Configuration
# ============================================

# ── GMAIL (required for email features) ─────────────────────────
# Get from: https://console.cloud.google.com/applications/credentials
GMAIL_CREDENTIALS_PATH=credentials.json

# ── LLM PROVIDER (choose ONE) ────────────────────────────────

# Option A: Groq (FREE - RECOMMENDED)
# Get free key: https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# Option B: Anthropic (free 5 calls/min)
# ANTHROPIC_API_KEY=sk-ant-api03-

# ── EMBEDDINGS (enable AI detection) ──────────────────────
# Set to "true" to enable embedding-based AI detection
# Requires GROQ_API_KEY
USE_EMBEDDINGS=false

# ── INTERNSHALA ────────────────────────────────────────────
INTERNSHALA_SESSION=
INTERNSHALA_BANNER=
INTERNSHALA_USER=
INTERNSHALA_JOB_URL=https://internshala.com/employers/applications/YOUR_JOB_ID
INTERNSHALA_PAGES=57

# ── ORCHESTRATOR ────────────────────────────────────────────
LOOP_INTERVAL_SECONDS=300

# ── DEMO ────────────────────────────────────────────────
HR_EMAIL=your_email@gmail.com
DEMO_CANDIDATE_EMAIL=your_email@gmail.com